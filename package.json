{
  "name": "vytal-fit",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@vytal-fit/web",
    "dev:mobile": "turbo dev --filter=@vytal-fit/mobile",
    "build": "turbo build",
    "build:web": "cd apps/web && next build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm --workspace @vytal-fit/web run test:e2e",
    "test:e2e:ui": "npm --workspace @vytal-fit/web run test:e2e:ui",
    "docs:readme:openapi": "rdme openapi upload https://api.vytal.fit/openapi --slug vytal-api --title \"Vytal API\" --branch 1.0 --confirm-overwrite",
    "docs:readme:guides": "rdme docs upload readme/docs --branch 1.0",
    "docs:readme:sync": "npm run docs:readme:openapi && npm run docs:readme:guides"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.6",
    "ajv": "^8.20.0",
    "rdme": "^10.9.1",
    "turbo": "^2.5.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  },
  "packageManager": "npm@11.7.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "postcss": "^8.5.14",
    "esbuild": "^0.28.0"
  },
  "dependencies": {
    "expo": "~54.0.0",
    "expo-secure-store": "~15.0.8",
    "expo-system-ui": "~6.0.9",
    "gray-matter": "^4.0.3",
    "react-markdown": "^10.1.0",
    "react-native-worklets": "^0.9.1",
    "remark-gfm": "^4.0.1"
  }
}
