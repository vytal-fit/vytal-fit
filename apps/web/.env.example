# Database
DATABASE_URL=postgresql://localhost:5432/vytal

# Auth
BETTER_AUTH_SECRET=generate-with-node-crypto
BETTER_AUTH_URL=http://localhost:3001

# Public admin app origin used by the marketing-site "Sign In" link.
# Leave UNSET in dev/preview so sign-in stays same-origin (localhost:3001) —
# pointing it at production loses local session cookies and breaks login.
# In production set this to the admin subdomain, e.g. https://pro.vytal.fit
# NEXT_PUBLIC_ADMIN_URL=https://pro.vytal.fit

# STORAGE
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# EMAIL
BREVO_API_KEY=
EMAIL_FROM=Vytal Fit <vytal.fit.eu@gmail.com>
EMAIL_PROVIDER=brevo
EMAIL_REPLY_TO=no-reply@vytal.fit