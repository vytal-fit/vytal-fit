# Database
DATABASE_URL=postgresql://localhost:5432/vytal

# Auth
BETTER_AUTH_SECRET=generate-with-node-crypto
BETTER_AUTH_URL=http://localhost:3001

# Public app origin used by auth emails and redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Public API origin used by the web client.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Production auth origin for the web app.
# Keep this aligned with the deployed API host serving /api/auth/*.
# BETTER_AUTH_URL=https://api.vytal.fit

# Legacy admin/app origin fallback for the marketing-site "Sign In" link.
# Prefer NEXT_PUBLIC_APP_URL above. Leave UNSET in dev/preview so sign-in
# stays same-origin (localhost:3001) — pointing it at production loses local
# session cookies and breaks login.
# NEXT_PUBLIC_ADMIN_URL=https://pro.vytal.fit

# STORAGE
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# EMAIL
BREVO_API_KEY=
EMAIL_FROM=Vytal Fit <vytal.fit.eu@gmail.com>
EMAIL_PROVIDER=brevo
EMAIL_REPLY_TO=no-reply@vytal.fit
