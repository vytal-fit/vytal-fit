# ──────────────────────────────────────────────────────────────────────────────
# Vytal — backend environment
# Copy to .env (root) or apps/web/.env.local. None of these are required to
# build or type-check; missing vars cause API routes to answer 503 at runtime.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Drizzle ORM + Better Auth storage).
DATABASE_URL=postgresql://localhost:5432/vytal

# Secret used by Better Auth to sign/encrypt sessions and tokens.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL of the app serving the auth routes (/api/auth/*).
# Local: http://localhost:3000 — Production: https://vytal.fit
BETTER_AUTH_URL=http://localhost:3000

# Mobile API base URL used by Expo Go / native builds.
# Android emulator: http://10.0.2.2:3000
# iOS simulator: http://127.0.0.1:3000
EXPO_PUBLIC_API_URL=http://127.0.0.1:3000
